{
  "manifest_version": 3,
  "name": "Anishka Autofill",
  "version": "1.0.0",
  "description": "Autofills common application fields with Anishka Jannu's details.",
  "permissions": [
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "Anishka Autofill",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
